# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend (Email Service) - https://resend.com
# You need to sign up and verify your domain
RESEND_API_KEY=re_your_resend_api_key

# Zoom Server-to-Server OAuth - https://marketplace.zoom.us/
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_WEBINAR_ID=your_recurring_webinar_id

# Checkout URL
NEXT_PUBLIC_CHECKOUT_URL=https://ai-scale.circle.so/checkout/aiscaleapp-aylik
